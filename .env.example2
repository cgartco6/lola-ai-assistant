# ------------------------------------------------------------
#  LOLA ENVIRONMENT VARIABLES
#  Copy this file to .env and fill in your keys
# ------------------------------------------------------------

# --- Primary LLM (choose one) ---
# Option A: Mistral AI (free tier, recommended)
MISTRAL_API_KEY=your_mistral_api_key_here

# Option B: OpenAI (if you have a key, else leave blank)
OPENAI_API_KEY=

# Option C: Local Ollama (no key needed)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2:latest

# Which LLM to use? 'mistral', 'openai', or 'ollama'
LLM_PROVIDER=mistral

# --- Other APIs ---
WEATHER_API_KEY=your_openweather_api_key
NEWS_API_KEY=your_newsapi_api_key

# --- TTS Engine ---
# 'pyttsx3' (offline) or 'gtts' (online, needs internet)
TTS_ENGINE=pyttsx3

# --- Radio ---
RADIO_STREAM=https://zas4.ndx.co.za/proxy/bokradio?mp=/stream

# --- Default GPS (fallback if browser doesn't send) ---
DEFAULT_LAT=-26.2041
DEFAULT_LON=28.0473
