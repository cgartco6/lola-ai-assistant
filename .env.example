# ------------------------------------------------------------
#  LOLA ENVIRONMENT VARIABLES
# ------------------------------------------------------------

# --- LLM Provider ---
LLM_PROVIDER=mistral
MISTRAL_API_KEY=your_mistral_api_key_here
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2:latest

# --- Other APIs ---
WEATHER_API_KEY=your_openweather_api_key
NEWS_API_KEY=your_newsapi_api_key
TOMTOM_API_KEY=your_tomtom_api_key   # for traffic & speed limits

# --- Supabase (free tier) for memory ---
# Sign up at https://supabase.com/ – create a new project
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# --- TTS ---
TTS_ENGINE=pyttsx3

# --- Radio ---
RADIO_STREAM=https://zas4.ndx.co.za/proxy/bokradio?mp=/stream

# --- Default GPS ---
DEFAULT_LAT=-26.2041
DEFAULT_LON=28.0473
